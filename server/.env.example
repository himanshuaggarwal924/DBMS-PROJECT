DB_HOST=localhost
DB_USER=root
DB_PASSWORD=YourNewPassword
DB_NAME=travel_planner
PORT=5000

# Auth – use a long, random secret in production
JWT_SECRET=change_me_in_production_use_a_long_random_string

# CORS – comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Email – leave blank to use dev previewPath fallback instead of sending real emails
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=you@gmail.com
# URL shown in the reset link sent to users
FRONTEND_URL=http://localhost:5173
